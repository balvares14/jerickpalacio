# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Storage bucket name (created by supabase/setup.sql)
VITE_SUPABASE_STORAGE_BUCKET=portfolio-media

# Note: Supabase Storage is used — no separate AWS S3 region/endpoint keys needed
# in the frontend. Uploads go through the Supabase client using the URL + key above.
